{
  "fps": 30,
  "durationInFrames": 1050,
  "beats": [
    {
      "id": "launch",
      "startFrame": 0,
      "endFrame": 150,
      "terminal": {
        "lines": [
          { "text": "> Log into the pricing portal and grab today's rates", "color": "user", "framesPerChar": 1 },
          { "text": "", "color": "default", "delay": 15 },
          { "text": "$ launch_session(headless=false)", "color": "command", "framesPerChar": 2 },
          { "text": "  \u2713 Browser launched", "color": "success", "delay": 15 },
          { "text": "", "color": "default", "delay": 3 },
          { "text": "$ scout_page_tool()", "color": "command", "framesPerChar": 2 }
        ]
      },
      "browser": { "scene": "landing", "shieldState": "solid" }
    },
    {
      "id": "scout",
      "startFrame": 150,
      "endFrame": 340,
      "terminal": {
        "lines": [
          { "text": "  Scout Report:", "color": "success", "delay": 5 },
          { "text": "    Elements: 47 | Forms: 2 | Buttons: 8", "color": "default", "delay": 8 },
          { "text": "    Found login form at #signin", "color": "default", "delay": 8 },
          { "text": "", "color": "default", "delay": 8 },
          { "text": "  I see a login form. Signing in now.", "color": "muted", "delay": 10 },
          { "text": "", "color": "default", "delay": 5 },
          { "text": "$ find_elements(text=\"Login\")", "color": "command", "framesPerChar": 2 },
          { "text": "  Found: button#login-btn", "color": "success", "delay": 15 }
        ]
      },
      "browser": { "scene": "page-loaded", "shieldState": "cracking" }
    },
    {
      "id": "interact",
      "startFrame": 340,
      "endFrame": 500,
      "terminal": {
        "lines": [
          { "text": "$ fill_secret(\"#email\", env=\"EMAIL\")", "color": "command", "framesPerChar": 1 },
          { "text": "  \u2713 Typed 22 chars (hidden)", "color": "success", "delay": 6 },
          { "text": "$ fill_secret(\"#password\", env=\"PASSWORD\")", "color": "command", "framesPerChar": 1 },
          { "text": "  \u2713 Typed 16 chars (hidden)", "color": "success", "delay": 6 },
          { "text": "$ execute_action(\"click\", \"#login-btn\")", "color": "command", "framesPerChar": 1 },
          { "text": "  \u2713 Clicked \u2014 page loaded", "color": "success", "delay": 5 }
        ]
      },
      "browser": { "scene": "form-fill", "shieldState": "dissolved" }
    },
    {
      "id": "captured",
      "startFrame": 500,
      "endFrame": 600,
      "terminal": {
        "lines": [
          { "text": "", "color": "default", "delay": 5 },
          { "text": "  Found pricing data for 3 plans:", "color": "muted", "delay": 10 },
          { "text": "    Enterprise $499/mo | Pro $199/mo | Starter $49/mo", "color": "data", "delay": 15 }
        ]
      },
      "browser": { "scene": "pricing", "shieldState": "dissolved" }
    },
    {
      "id": "pre-export",
      "startFrame": 600,
      "endFrame": 740,
      "terminal": {
        "lines": [
          { "text": "", "color": "default", "delay": 10 },
          { "text": "> Export this as a workflow I can run daily", "color": "user", "framesPerChar": 1 },
          { "text": "", "color": "default", "delay": 12 },
          { "text": "$ get_session_history()", "color": "command", "framesPerChar": 2 },
          { "text": "  \u2713 6 actions recorded", "color": "success", "delay": 20 }
        ]
      },
      "browser": { "scene": "pricing", "shieldState": "dissolved" }
    },
    {
      "id": "export",
      "startFrame": 740,
      "endFrame": 860,
      "terminal": {
        "lines": [
          { "text": "  \u2713 login-workflow.py", "color": "success", "delay": 10 },
          { "text": "  \u2713 login-workflow.json", "color": "success", "delay": 15 }
        ]
      },
      "browser": { "scene": "export", "shieldState": "dissolved" }
    },
    {
      "id": "schedule",
      "startFrame": 860,
      "endFrame": 980,
      "terminal": {
        "lines": [
          { "text": "", "color": "default", "delay": 5 },
          { "text": "> Schedule it every morning at 9", "color": "user", "framesPerChar": 1 },
          { "text": "", "color": "default", "delay": 10 },
          { "text": "$ schedule_create(", "color": "command", "framesPerChar": 2 },
          { "text": "    name=\"daily-pricing\",", "color": "command", "framesPerChar": 1 },
          { "text": "    cron=\"0 9 * * *\"", "color": "command", "framesPerChar": 1 },
          { "text": "  )", "color": "command", "delay": 3 },
          { "text": "  \u2713 Scheduled: daily at 9:00 AM", "color": "success", "delay": 15 }
        ]
      },
      "browser": { "scene": "schedule", "shieldState": "dissolved" }
    },
    {
      "id": "outro",
      "startFrame": 980,
      "endFrame": 1050,
      "terminal": { "lines": [] },
      "browser": { "scene": "outro", "shieldState": "dissolved" }
    }
  ]
}
